{
  "hooks": {
    "PermissionRequest": [
      {
        "matcher": "Bash|Read|Edit|Write|Glob|Grep|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -l JavaScript /Users/01061279/dotfiles/claude/permission-hook.js 3<&0"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Task completed\" sound name \"alert\"' 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
